# ============================================================
# PulseGuard — .gitignore
# Node.js + Vite/React + Express Monorepo
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build Output ───────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.vite/

# ─── Environment Variables ──────────────────────────────────
# Never commit secrets!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Runtime & Cache ────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ─── Testing ────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── Yarn / pnpm ────────────────────────────────────────────
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ─── Docker (if used later) ─────────────────────────────────
docker-compose.override.yml

# ─── Misc ───────────────────────────────────────────────────
*.local
